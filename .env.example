# Duplicate this file as .env and fill in your keys
# DO NOT commit your actual .env file to GitHub!

# AI Model API Keys (Required for CodeReviewAgent)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Backend Configuration
BACKEND_PORT=7860
HOST=127.0.0.1
DEBUG=True

# Optional: Frontend URL (for Redirection)
# Security
APP_API_KEY=openenv_secret_key_123
